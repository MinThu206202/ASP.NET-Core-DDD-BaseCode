@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.ProductViewModel>

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Products</h1>
            <p class="text-slate-500 text-sm mt-1">Manage your Product records</p>
        </div>
        <a asp-action="Create"
           class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-lg shadow-indigo-200 hover:shadow-indigo-300 transition-all duration-200 hover:-translate-y-0.5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Create Product
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Name</th>
<th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase">
                Price
            </th>
<th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase">
                Description
            </th>
<th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase">
                Quantity
            </th>
<th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase">
                Category
            </th>
<th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase">Images</th>

                        <th class="text-right px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
@foreach (var p in Model.Items)
{
                    <tr class="hover:bg-indigo-50/40 transition-colors duration-150">
                        <td class="px-6 py-4 font-semibold text-slate-800">@p.Name</td>
<td class="px-6 py-4 text-slate-600">@p.Price</td>
<td class="px-6 py-4 text-slate-600">@p.Description</td>
<td class="px-6 py-4 text-slate-600">@p.Quantity</td>
<td class="px-6 py-4 text-slate-600">@(!string.IsNullOrEmpty(p.CategoryName) ? p.CategoryName : "—")</td>

<td class="px-6 py-4">
    @if (p.ImageUrls.Count > 0)
    {
        <div class="flex gap-1.5">
        @foreach (var img in p.ImageUrls.Take(3))
        {
            <img src="@img" class="w-10 h-10 rounded-lg object-cover" />
        }
        </div>
    }
</td>

                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@p.Id"
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                    Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline">
                                    <button type="button" data-confirm-delete
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-rose-600 bg-rose-50 hover:bg-rose-100 rounded-lg transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
}
                </tbody>
            </table>
        </div>

@if (!Model.Items.Any())
{
        <div class="text-center py-16">
            <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            <p class="text-slate-500 font-medium">No Products found</p>
            <p class="text-slate-400 text-sm mt-1">Create your first Product to get started.</p>
        </div>
}
    </div>

@if (Model.TotalCount > Model.PageSize)
{
    <div class="flex items-center justify-between mt-6">
        <p class="text-sm text-slate-500">
            Showing <span class="font-bold">@((Model.Page - 1) * Model.PageSize + 1)</span>
            to <span class="font-bold">@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</span>
            of <span class="font-bold">@Model.TotalCount</span> items
        </p>
        <div class="flex gap-2">
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-size="@Model.PageSize"
                   class="px-4 py-2 text-sm font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors shadow-sm">
                    Previous
                </a>
            }
            @if (Model.Page * Model.PageSize < Model.TotalCount)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-size="@Model.PageSize"
                   class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                    Next
                </a>
            }
        </div>
    </div>
}
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
