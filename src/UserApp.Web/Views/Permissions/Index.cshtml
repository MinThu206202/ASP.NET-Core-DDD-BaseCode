@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.Permissions.PermissionViewModel>

<div class="animate-fade-in space-y-6">
    <div class="flex items-center justify-between mb-2">
        <div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">System Permissions</h1>
            <p class="text-slate-500 text-sm mt-1">Manage core authorization vectors and assembly signatures</p>
        </div>
        <div class="flex items-center gap-3">
            <form method="post" asp-action="Sync" style="display:inline">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-bold rounded-xl shadow-sm transition-all duration-200">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Sync
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        
        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                <p class="text-slate-500 font-medium">No permissions found</p>
                <p class="text-slate-400 text-sm mt-1">Register a system permission security token signature key to get started.</p>
            </div>
        }
        else
        {
            @* Extract and sort groups logically *@
            var groupedPermissions = Model.Items
                .GroupBy(p => p.Name.Split('.')[0].Split(' ')[0]) 
                .OrderBy(g => g.Key)
                .ToList();

            for (int i = 0; i < groupedPermissions.Count; i++)
            {
                var group = groupedPermissions[i];

                @if (i > 0)
                {
                    <div class="border-t-2 border-dashed border-slate-100 my-2"></div>
                }

                <div class="bg-slate-50/60 px-6 py-3 flex items-center justify-between border-b border-slate-100">
                    <div class="flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
                        <h2 class="text-xs font-black text-slate-600 uppercase tracking-wider">@group.Key Operations</h2>
                    </div>
                    <span class="text-[11px] font-bold text-slate-400">
                        @group.Count() Items
                    </span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full">
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var p in group.OrderBy(p => p.Name))
                            {
                                <tr class="hover:bg-indigo-50/30 transition-colors duration-150 group">
                                    <td class="px-6 py-4 whitespace-nowrap w-1/4">
                                        <span class="font-semibold text-slate-800 text-sm">@p.Name</span>
                                    </td>
                                    <td class="px-6 py-4 text-right whitespace-nowrap w-1/4"></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>

    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="flex items-center justify-between mt-6 pt-2">
            <p class="text-sm text-slate-500">
                Showing <span class="font-bold">@((Model.Page - 1) * Model.PageSize + 1)</span>
                to <span class="font-bold">@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</span>
                of <span class="font-bold">@Model.TotalCount</span> total rules
            </p>
            <div class="flex gap-2">
                @if (Model.Page > 1)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-size="@Model.PageSize"
                       class="px-4 py-2 text-sm font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors shadow-sm">
                        Previous
                    </a>
                }
                @if (Model.Page * Model.PageSize < Model.TotalCount)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-size="@Model.PageSize"
                       class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                        Next
                    </a>
                }
            </div>
        </div>
    }
</div>

<style>
    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>