@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">@ViewData["Title"]</h1>
            <p class="text-slate-500 text-sm mt-1">View system users and their authentication statuses Min Thu</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Email</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Full Name</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Roles</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Created</th>
                        <th class="text-right px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var u in Model.Items)
                    {
                        <tr class="hover:bg-indigo-50/40 transition-colors duration-150 group">
                            <td class="px-6 py-4 font-mono text-sm text-slate-600">
                                @u.Email
                            </td>
                            <td class="px-6 py-4">
                                <span class="font-semibold text-slate-800">@u.FullName</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (u.Status?.ToString().ToLower() == "active")
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 text-xs font-bold bg-emerald-50 text-emerald-700 rounded-lg border border-emerald-100">
                                        @u.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 text-xs font-bold bg-slate-100 text-slate-600 rounded-lg border border-slate-200">
                                        @u.Status
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var r in u.Roles)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold bg-indigo-50 text-indigo-700 rounded-md border border-indigo-100">
                                            @r
                                        </span>
                                    }
                                    @if (!u.Roles.Any())
                                    {
                                        <span class="text-xs text-slate-400 italic">None</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-500">
                                @u.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="ManageRoles" asp-route-userId="@u.Id"
                                   class="inline-flex items-center gap-1 px-2.5 py-1.5 font-semibold text-xs text-indigo-700 bg-indigo-50/50 hover:bg-indigo-50 border border-indigo-100 hover:border-indigo-200 rounded-lg transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                                    </svg>
                                    Roles
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                <p class="text-slate-500 font-medium">No users found</p>
                <p class="text-slate-400 text-sm mt-1">There are currently no accounts registered in the database module.</p>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-between mt-6">
            <p class="text-sm text-slate-500">
                Page <span class="font-bold text-slate-700">@Model.Page</span> of <span class="font-bold text-slate-700">@Model.TotalPages</span>
            </p>
            <div class="flex gap-2">
                @if (Model.Page > 1)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page - 1)"
                       class="px-4 py-2 text-sm font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors shadow-sm">
                        Previous
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 text-sm font-bold text-slate-300 bg-slate-50 border border-slate-100 rounded-xl cursor-not-allowed">
                        Previous
                    </span>
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(Model.Page + 1)"
                       class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                        Next
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 text-sm font-bold text-white bg-indigo-400 rounded-xl cursor-not-allowed">
                        Next
                    </span>
                }
            </div>
        </div>
    }
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>