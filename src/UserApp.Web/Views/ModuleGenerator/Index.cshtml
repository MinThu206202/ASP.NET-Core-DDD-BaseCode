    function toggleDetails(btn) {
        if (!btn) return;
        var row = btn.closest('tr');
        if (!row) return;
        var idx = row.dataset.index;
        var tbody = row.parentElement;
        if (!tbody) return;
        var dr = tbody.querySelector('tr.detail-row[data-index="' + idx + '"]');
        if (!dr) return;
        if (dr.classList.contains('hidden')) {
            dr.classList.remove('hidden');
            btn.classList.add('text-indigo-600', 'bg-indigo-50', 'border-indigo-100');
        } else {
            dr.classList.add('hidden');
            btn.classList.remove('text-indigo-600', 'bg-indigo-50', 'border-indigo-100');
        }
    }

    function onTypeChange(select) {
        if (!select) return;
        var row = select.closest('tr');
        if (!row) return;
        var idx = row.dataset.index;
        var tbody = row.parentElement;
        if (!tbody) return;
        var dr = tbody.querySelector('tr.detail-row[data-index="' + idx + '"]');
        if (!dr) return;
        var isEnum = select.value === 'enum';
        var isRel = select.value === 'relation';
        var relInput = dr.querySelector('input[data-field="IsRelation"]');
        if (relInput) relInput.disabled = !isRel;
        var lenInput = row.querySelector('.field-len-input');
        var valP = dr.querySelector('.validation-settings-panel');
        var enumP = dr.querySelector('.enum-settings-panel');
        var relP = dr.querySelector('.relation-settings-panel');
        var dtBtn = row.querySelector('.details-toggle-btn');
        if (lenInput) {
            if (select.value === 'string' || select.value === 'int' || select.value === 'decimal') {
                lenInput.disabled = false; lenInput.classList.remove('opacity-40'); lenInput.placeholder = '\u2014';
            } else {
                lenInput.disabled = true; lenInput.value = ''; lenInput.classList.add('opacity-40'); lenInput.placeholder = 'N/A';
            }
        }
        if (enumP) enumP.classList.add('hidden');
        if (relP) relP.classList.add('hidden');
        if (valP) valP.classList.remove('hidden');
        if (isEnum) {
            if (enumP) enumP.classList.remove('hidden');
            if (valP) valP.classList.add('hidden');
            dr.classList.remove('hidden');
            if (dtBtn) { dtBtn.classList.add('text-indigo-600', 'bg-indigo-50', 'border-indigo-100'); var s = dtBtn.querySelector('span'); if (s) s.textContent = 'Options'; }
            var cb = enumP && enumP.querySelector('.use-common-table-cb');
            if (cb) onUseCommonTableChange(cb);
        } else if (isRel) {
            if (relP) relP.classList.remove('hidden');
            if (valP) valP.classList.add('hidden');
            dr.classList.remove('hidden');
            if (dtBtn) { dtBtn.classList.add('text-indigo-600', 'bg-indigo-50', 'border-indigo-100'); var s = dtBtn.querySelector('span'); if (s) s.textContent = 'Relation'; }
        } else {
            if (dtBtn) { var s = dtBtn.querySelector('span'); if (s) s.textContent = 'Validation'; }
        }
        updateValidationInputNames(row);
    }

    function onUseCommonTableChange(cb) {
        if (!cb) return;
        var p = cb.closest('.enum-settings-panel');
        if (!p) return;
        var h = p.querySelector('.common-table-hint');
        if (h) h.classList.toggle('hidden', !cb.checked);
        var rt = p.querySelector('.render-type-toggle');
        if (rt) rt.classList.toggle('hidden', !!cb.checked);
    }

    function onRelationTableChange(select) {
        if (!select) return;
        var dr = select.closest('tr.detail-row');
        if (!dr) return;
        var idx = dr.dataset.index;
        var tbody = dr.parentElement;
        if (!tbody) return;
        var fr = tbody.querySelector('tr.field-row[data-index="' + idx + '"]');
        if (!fr) return;
        var ni = fr.querySelector('input[data-field="Name"]');
        if (!ni) return;
        var h = dr.querySelector('.field-related-entity');
        if (h) h.value = select.value;
        if (select.value && (!ni.value || availableTables.indexOf(ni.value) !== -1)) ni.value = select.value;
    }

    function onRelationSelect() {
        var sel = document.getElementById('relTableSelect');
        var tbl = sel.value;
        var hc = document.getElementById('relationFieldsContainer');
        var dr = document.getElementById('deleteBehaviorRow');
        var pc = document.getElementById('pivotCard');
        var pt = document.getElementById('pivotTitle');
        var pcb = pc.querySelector('.relation-pivot-cb');
        if (!tbl) {
            dr.style.display = 'none'; hc.innerHTML = ''; pc.style.display = 'none'; pc.style.opacity = '0.5'; pt.textContent = 'Pivot'; pcb.disabled = true; pcb.checked = false; return;
        }
        dr.style.display = ''; pc.style.display = ''; pc.style.opacity = '1'; pt.textContent = tbl + ' Pivot'; pcb.disabled = false;
        hc.innerHTML = '<input type="hidden" name="_rel_Name" value="' + tbl + '" /><input type="hidden" name="_rel_IsPivot" value="false" /><input type="hidden" name="_rel_DeleteBehavior" value="Cascade" />';
    }

    function clearRelation() {
        document.getElementById('relTableSelect').value = '';
        document.getElementById('deleteBehaviorRow').style.display = 'none';
        document.getElementById('relationFieldsContainer').innerHTML = '';
        var pc = document.getElementById('pivotCard');
        pc.style.display = 'none'; pc.style.opacity = '0.5';
        document.getElementById('pivotTitle').textContent = 'Pivot';
        var pcb = pc.querySelector('.relation-pivot-cb');
        pcb.disabled = true; pcb.checked = false;
    }

    function onDeleteBehaviorChange(radio) {
        var hc = document.getElementById('relationFieldsContainer');
        var e = hc.querySelector('input[name="_rel_DeleteBehavior"]');
        if (e) e.value = radio.value;
    }

    function handleAddTagClick(btn) {
        if (!btn) return;
        var p = btn.closest('.enum-settings-panel');
        if (!p) return;
        var i = p.querySelector('.tag-input');
        if (i) addOptionTag(i);
    }

    function addOptionTag(input) {
        if (!input) return;
        var v = input.value.trim();
        if (!v) return;
        if (v.indexOf(',') > -1) { v.split(',').forEach(function(x) { addOptionTagFromString(x.trim(), input); }); input.value = ''; return; }
        addOptionTagFromString(v, input); input.value = ''; input.focus();
    }

    function addOptionTagFromString(value, input) {
        if (!value || !input) return;
        var p = input.closest('.enum-settings-panel');
        if (!p) return;
        var c = p.querySelector('.tag-container');
        if (!c) return;
        var ph = c.querySelector('.placeholder-msg');
        if (ph) ph.style.display = 'none';
        var existing = c.querySelectorAll('.tag');
        for (var i = 0; i < existing.length; i++) { if (existing[i].dataset.val.toLowerCase() === value.toLowerCase()) return; }
        var tag = document.createElement('span');
        tag.className = 'tag';
        tag.dataset.val = value;
        tag.innerHTML = value + ' <button type="button" onclick="removeOptionTag(this)">\u00d7</button>';
        var h = c.querySelector('.field-enum');
        c.insertBefore(tag, h);
        updateEnumHidden(c);
    }

    function removeOptionTag(btn) {
        if (!btn) return;
        var c = btn.closest('.tag-container');
        if (!c) return;
        btn.parentElement.remove();
        if (c.querySelectorAll('.tag').length === 0) { var ph = c.querySelector('.placeholder-msg'); if (ph) ph.style.display = ''; }
        updateEnumHidden(c);
    }

    function updateEnumHidden(container) {
        if (!container) return;
        var h = container.querySelector('.field-enum');
        if (!h) return;
        var tags = container.querySelectorAll('.tag');
        var vals = [];
        for (var i = 0; i < tags.length; i++) vals.push(tags[i].dataset.val);
        h.value = vals.join(',');
    }

    function removeField(button) {
        if (!button) return;
        var row = button.closest('tr');
        if (!row) return;
        var idx = row.dataset.index;
        var tbody = row.parentElement;
        if (!tbody) return;
        var dr = tbody.querySelector('tr.detail-row[data-index="' + idx + '"]');
        row.classList.add('opacity-0', '-translate-x-4', 'transition-all', 'duration-200');
        if (dr) dr.classList.add('opacity-0', '-translate-x-4');
        setTimeout(function() { row.remove(); if (dr) dr.remove(); reindexFields(); updateFieldCount(); }, 200);
    }

    function reindexFields() {
        var rows = document.querySelectorAll('#fieldsTable tbody tr.field-row');
        rows.forEach(function(row, ri) {
            row.dataset.index = ri;
            row.querySelectorAll('[data-field]').forEach(function(inp) { inp.name = 'Fields[' + ri + '].' + inp.dataset.field; });
            var tbody = row.parentElement;
            if (tbody) {
                var drs = tbody.querySelectorAll('tr.detail-row');
                var md = drs[ri];
                if (md) {
                    md.dataset.index = ri;
                    md.querySelectorAll('[data-field]').forEach(function(inp) { inp.name = 'Fields[' + ri + '].' + inp.dataset.field; });
                    var tc = md.querySelector('.tag-container');
                    if (tc) tc.dataset.row = ri;
                }
            }
            updateValidationInputNames(row, ri);
        });
        index = rows.length;
    }

    function updateValidationInputNames(row, rowIndex) {
        if (!row) return;
        if (rowIndex === undefined) {
            var te = row.parentElement;
            if (!te) return;
            var all = Array.from(te.children).filter(function(r) { return r.classList.contains('field-row'); });
            rowIndex = all.indexOf(row);
        }
        var tbody = row.parentElement;
        if (!tbody) return;
        var dr = tbody.querySelector('tr.detail-row[data-index="' + row.dataset.index + '"]');
        if (!dr) return;
        var ts = row.querySelector('.field-type');
        if (!ts) return;
        var type = ts.value;
        var minI = dr.querySelector('.field-min'), maxI = dr.querySelector('.field-max');
        var minL = dr.querySelector('.min-label'), maxL = dr.querySelector('.max-label');
        if (!minI || !maxI) return;
        var num = type === 'int' || type === 'decimal';
        var isEnum = type === 'enum', isRel = type === 'relation';
        minI.removeAttribute('name'); maxI.removeAttribute('name');
        minI.disabled = isEnum || isRel; maxI.disabled = isEnum || isRel;
        minI.step = '1'; maxI.step = '1';
        if (type === 'string') {
            minI.name = 'Fields[' + rowIndex + '].MinLength'; maxI.name = 'Fields[' + rowIndex + '].MaxLength';
            if (minL) minL.textContent = 'Min Length'; if (maxL) maxL.textContent = 'Max Length';
        } else if (num) {
            minI.name = 'Fields[' + rowIndex + '].MinValue'; maxI.name = 'Fields[' + rowIndex + '].MaxValue';
            if (minL) minL.textContent = 'Min Value'; if (maxL) maxL.textContent = 'Max Value';
            if (type === 'decimal') { minI.step = '0.01'; maxI.step = '0.01'; }
        } else {
            if (minL) minL.textContent = 'Min Config'; if (maxL) maxL.textContent = 'Max Config';
            minI.value = ''; maxI.value = '';
        }
    }

    // ========================================================================
    // DOM READY
    // ========================================================================
    document.addEventListener('DOMContentLoaded', function() {
        buildSidebarData();
        renderSidebar();
        toggleSidebarPreview();

        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('relation-pivot-cb')) {
                var val = e.target.checked ? 'true' : 'false';
                var hc = document.getElementById('relationFieldsContainer');
                var ex = hc.querySelector('input[name="_rel_IsPivot"]');
                if (ex) ex.value = val;
            }
        });

        var toggler = document.querySelector('.toggler-relation');
        var selector = document.getElementById('relationSelector');
        if (toggler && selector) {
            toggler.addEventListener('change', function() {
                if (toggler.checked) { selector.style.opacity = '1'; selector.style.pointerEvents = 'auto'; }
                else { selector.style.opacity = '0.5'; selector.style.pointerEvents = 'none'; clearRelation(); }
            });
        }

        // Live preview: show typed module name in sidebar
        var moduleInput = document.getElementById('moduleNameInput');
        if (moduleInput) {
            moduleInput.addEventListener('input', function() {
                var name = this.value.trim();
                var preview = document.getElementById('sidebarPreviewNew');
                var nameEl = document.getElementById('sidebarPreviewName');
                if (!preview || !nameEl) return;
                if (name) {
                    nameEl.textContent = name;
                    preview.classList.remove('hidden');
                } else {
                    preview.classList.add('hidden');
                }
            });
        }

        // Click sidebar module → navigate to its index page
        document.addEventListener('click', function(e) {
            var link = e.target.closest('#sidebarPreviewContent .sidebar-item-link');
            if (link && !e.target.closest('.item-actions')) {
                var controller = link.getAttribute('data-controller');
                if (controller) {
                    window.location.href = '/' + controller + '/Index';
                }
            }
        });

        // Auto-show sidebar on success
        var successMsg = '@TempData["Success"]';
        if (successMsg) {
            showToast(successMsg, 'success');
            var toggle = document.getElementById('sidebarToggle');
            if (toggle && !toggle.checked) {
                toggle.checked = true;
                toggleSidebarPreview();
            }
        }
        var errorMsg = '@TempData["Error"]';
        if (errorMsg) showToast(errorMsg, 'error');
    });
</script>
