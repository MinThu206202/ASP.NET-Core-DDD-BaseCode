@model UserApp.Web.ViewModels.ModuleGenerator.GenerateModuleViewModel

<h2>Module Designer</h2>

<form method="post">

    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label>Module Name</label>
        <input asp-for="ModuleName" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="RunMigration" class="form-check-input" />
        <label asp-for="RunMigration" class="form-check-label">Run Migration</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="RunDbUpdate" class="form-check-input" />
        <label asp-for="RunDbUpdate" class="form-check-label">Run Database Update</label>
    </div>

    <div class="form-group mb-3">
    <label>Image Support</label>

    <div class="form-check">
        <input class="form-check-input" type="radio" asp-for="HasImage" value="true" />
        <label class="form-check-label">Yes (Enable Image)</label>
    </div>

    <div class="form-check">
        <input class="form-check-input" type="radio" asp-for="HasImage" value="false" />
        <label class="form-check-label">No Image</label>
    </div>
</div>

    <hr />

    <h4>Fields Designer</h4>

    <table class="table" id="fieldsTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Length</th>
                <th>Required</th>
                <th>Nullable</th>
                <th>Min</th>
                <th>Max</th>
                <th></th>
            </tr>
        </thead>

        <tbody></tbody>
    </table>

    <button type="button" class="btn btn-success" onclick="addField()">
        + Add Field
    </button>

    <br /><br />

    <button type="submit" class="btn btn-primary">
        Generate Module
    </button>
</form>

<script>
let index = 0;

function addField() {
    const tbody = document.querySelector("#fieldsTable tbody");

    const row = document.createElement("tr");

    row.innerHTML = `
        <td>
            <input name="Fields[${index}].Name" class="form-control" data-field="Name" />
        </td>

        <td>
            <select name="Fields[${index}].Type" class="form-control field-type" data-field="Type" onchange="updateValidationInputNames(this.closest('tr'))">
                <option value="string">string</option>
                <option value="int">int</option>
                <option value="decimal">decimal</option>
                <option value="bool">bool</option>
                <option value="DateTime">DateTime</option>
            </select>
        </td>

        <td>
            <input name="Fields[${index}].Length" type="number" class="form-control" data-field="Length" />
        </td>

        <td class="text-center">
            <input type="checkbox" name="Fields[${index}].IsRequired" value="true" data-field="IsRequired" />
            <input type="hidden" name="Fields[${index}].IsRequired" value="false" data-field="IsRequired" />
        </td>

        <td class="text-center">
            <input type="checkbox" name="Fields[${index}].IsNullable" value="true" data-field="IsNullable" />
            <input type="hidden" name="Fields[${index}].IsNullable" value="false" data-field="IsNullable" />
        </td>

        <td>
            <input type="number" class="form-control field-min" />
        </td>

        <td>
            <input type="number" class="form-control field-max" />
        </td>

        <td>
            <button type="button" onclick="removeField(this)" class="btn btn-danger btn-sm">
                X
            </button>
        </td>
    `;

    tbody.appendChild(row);
    updateValidationInputNames(row);
    index++;
}

function removeField(button) {
    button.closest("tr").remove();
    reindexFields();
}

function reindexFields() {
    const rows = document.querySelectorAll("#fieldsTable tbody tr");

    rows.forEach((row, rowIndex) => {
        row.querySelectorAll("[data-field]").forEach(input => {
            input.name = `Fields[${rowIndex}].${input.dataset.field}`;
        });

        updateValidationInputNames(row, rowIndex);
    });

    index = rows.length;
}

function updateValidationInputNames(row, rowIndex = null) {
    const currentIndex = rowIndex ?? Array.from(row.parentElement.children).indexOf(row);
    const type = row.querySelector(".field-type").value;
    const minInput = row.querySelector(".field-min");
    const maxInput = row.querySelector(".field-max");
    const supportsNumericRange = type === "int" || type === "decimal";

    minInput.removeAttribute("name");
    maxInput.removeAttribute("name");
    minInput.disabled = false;
    maxInput.disabled = false;
    minInput.step = "1";
    maxInput.step = "1";

    if (type === "string") {
        minInput.name = `Fields[${currentIndex}].MinLength`;
        maxInput.name = `Fields[${currentIndex}].MaxLength`;
    } else if (supportsNumericRange) {
        minInput.name = `Fields[${currentIndex}].MinValue`;
        maxInput.name = `Fields[${currentIndex}].MaxValue`;

        if (type === "decimal") {
            minInput.step = "0.01";
            maxInput.step = "0.01";
        }
    } else {
        minInput.value = "";
        maxInput.value = "";
        minInput.disabled = true;
        maxInput.disabled = true;
    }
}
</script>
