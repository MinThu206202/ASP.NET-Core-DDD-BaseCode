function toggleDetails(btn) {
    if (!btn) return;
    var row = btn.closest('tr'); if (!row) return;
    var trIndex = row.dataset.index;
    var tbody = row.parentElement; if (!tbody) return;
    var targetDetailRow = tbody.querySelector('tr.detail-row[data-index="'+trIndex+'"]'); if (!targetDetailRow) return;
    if (targetDetailRow.classList.contains('hidden')) {
        targetDetailRow.classList.remove('hidden');
        btn.classList.add('text-indigo-600','bg-indigo-50','border-indigo-100');
    } else {
        targetDetailRow.classList.add('hidden');
        btn.classList.remove('text-indigo-600','bg-indigo-50','border-indigo-100');
    }
}

function onTypeChange(select) {
    if (!select) return;
    var row = select.closest('tr'); if (!row) return;
    var trIndex = row.dataset.index;
    var tbody = row.parentElement; if (!tbody) return;
    var detailRow = tbody.querySelector('tr.detail-row[data-index="'+trIndex+'"]'); if (!detailRow) return;
    var isEnum = select.value==='enum', isRelation = select.value==='relation';
    var isRelationInput = detailRow.querySelector('input[data-field="IsRelation"]');
    if (isRelationInput) isRelationInput.disabled = !isRelation;
    var lenInput=row.querySelector('.field-len-input'), valSettings=detailRow.querySelector('.validation-settings-panel'), enumSettings=detailRow.querySelector('.enum-settings-panel'), relationSettings=detailRow.querySelector('.relation-settings-panel'), detailToggleBtn=row.querySelector('.details-toggle-btn');
    if (lenInput) {
        if (select.value==='string'||select.value==='int'||select.value==='decimal') { lenInput.disabled=false; lenInput.classList.remove('opacity-40'); lenInput.placeholder='—'; }
        else { lenInput.disabled=true; lenInput.value=''; lenInput.classList.add('opacity-40'); lenInput.placeholder='N/A'; }
    }
    if (enumSettings) enumSettings.classList.add('hidden');
    if (relationSettings) relationSettings.classList.add('hidden');
    if (valSettings) valSettings.classList.remove('hidden');
    if (isEnum) {
        if (enumSettings) enumSettings.classList.remove('hidden');
        if (valSettings) valSettings.classList.add('hidden');
        detailRow.classList.remove('hidden');
        if (detailToggleBtn) { detailToggleBtn.classList.add('text-indigo-600','bg-indigo-50','border-indigo-100'); var s=detailToggleBtn.querySelector('span'); if(s) s.textContent='Options'; }
        var cb=enumSettings&&enumSettings.querySelector('.use-common-table-cb'); if(cb) onUseCommonTableChange(cb);
    } else if (isRelation) {
        if (relationSettings) relationSettings.classList.remove('hidden');
        if (valSettings) valSettings.classList.add('hidden');
        detailRow.classList.remove('hidden');
        if (detailToggleBtn) { detailToggleBtn.classList.add('text-indigo-600','bg-indigo-50','border-indigo-100'); var s=detailToggleBtn.querySelector('span'); if(s) s.textContent='Relation'; }
    } else {
        if (detailToggleBtn) { var s=detailToggleBtn.querySelector('span'); if(s) s.textContent='Validation'; }
    }
    updateValidationInputNames(row);
}

function onUseCommonTableChange(cb) {
    if (!cb) return;
    var panel=cb.closest('.enum-settings-panel'); if (!panel) return;
    var hint=panel.querySelector('.common-table-hint');
    if (hint) { if(cb.checked) hint.classList.remove('hidden'); else hint.classList.add('hidden'); }
    var renderToggle=panel.querySelector('.render-type-toggle');
    if (renderToggle) { if(cb.checked) renderToggle.classList.add('hidden'); else renderToggle.classList.remove('hidden'); }
}

function onRelationTableChange(select) {
    if (!select) return;
    var row=select.closest('tr.detail-row'); if (!row) return;
    var trIndex=row.dataset.index;
    var tbody=row.parentElement; if (!tbody) return;
    var fieldRow=tbody.querySelector('tr.field-row[data-index="'+trIndex+'"]'); if (!fieldRow) return;
    var nameInput=fieldRow.querySelector('input[data-field="Name"]'); if (!nameInput) return;
    var hidden=row.querySelector('.field-related-entity'); if(hidden) hidden.value=select.value;
    if (select.value&&(!nameInput.value||availableTables.indexOf(nameInput.value)!==-1)) nameInput.value=select.value;
}

function onRelationSelect() {
    var select=document.getElementById('relTableSelect'), table=select.value;
    var hiddenContainer=document.getElementById('relationFieldsContainer'), deleteRow=document.getElementById('deleteBehaviorRow'), pivotCard=document.getElementById('pivotCard'), pivotTitle=document.getElementById('pivotTitle'), pivotCb=pivotCard.querySelector('.relation-pivot-cb');
    if (!table) { deleteRow.classList.add('hidden'); hiddenContainer.innerHTML=''; pivotCard.classList.add('hidden','opacity-50'); pivotTitle.textContent='Pivot'; pivotCb.disabled=true; pivotCb.checked=false; return; }
    deleteRow.classList.remove('hidden'); pivotCard.classList.remove('hidden','opacity-50'); pivotTitle.textContent=table+' Pivot'; pivotCb.disabled=false;
    hiddenContainer.innerHTML='<input type="hidden" name="_rel_Name" value="'+table+'" /><input type="hidden" name="_rel_IsPivot" value="false" /><input type="hidden" name="_rel_DeleteBehavior" value="Cascade" />';
}

function clearRelation() {
    var select=document.getElementById('relTableSelect'); select.value='';
    document.getElementById('deleteBehaviorRow').classList.add('hidden');
    document.getElementById('relationFieldsContainer').innerHTML='';
    var pivotCard=document.getElementById('pivotCard'); pivotCard.classList.add('hidden','opacity-50');
    document.getElementById('pivotTitle').textContent='Pivot';
    var pivotCb=pivotCard.querySelector('.relation-pivot-cb'); pivotCb.disabled=true; pivotCb.checked=false;
}

function onDeleteBehaviorChange(radio) {
    var existing=document.getElementById('relationFieldsContainer').querySelector('input[name="_rel_DeleteBehavior"]');
    if (existing) existing.value=radio.value;
}

function handleAddTagClick(btn) {
    if (!btn) return;
    var panel=btn.closest('.enum-settings-panel'); if (!panel) return;
    var input=panel.querySelector('.tag-input'); if (input) addOptionTag(input);
}

function addOptionTag(input) {
    if (!input) return;
    var value=input.value.trim(); if (!value) return;
    if (value.indexOf(',')>-1) { value.split(',').forEach(function(v){ addOptionTagFromString(v.trim(),input); }); input.value=''; return; }
    addOptionTagFromString(value,input); input.value=''; input.focus();
}

function addOptionTagFromString(value,input) {
    if (!value||!input) return;
    var panel=input.closest('.enum-settings-panel'); if (!panel) return;
    var container=panel.querySelector('.tag-container'); if (!container) return;
    var placeholder=container.querySelector('.placeholder-msg'); if (placeholder) placeholder.style.display='none';
    var existing=container.querySelectorAll('.tag');
    for (var i=0;i<existing.length;i++) { if (existing[i].dataset.val.toLowerCase()===value.toLowerCase()) return; }
    var tag=document.createElement('span');
    tag.className='tag inline-flex items-center gap-1.5 pl-2.5 pr-1.5 py-1 bg-indigo-50 border border-indigo-100 rounded-lg text-xs font-semibold text-indigo-600 leading-none';
    tag.dataset.val=value;
    tag.innerHTML=value+' <button type="button" class="text-indigo-400 hover:text-indigo-700 hover:bg-indigo-100/50 w-4 h-4 rounded inline-flex items-center justify-center font-bold text-xs leading-none transition-colors" onclick="removeOptionTag(this)">\u00d7</button>';
    var hiddenInput=container.querySelector('.field-enum'); container.insertBefore(tag,hiddenInput); updateEnumHidden(container);
}

function removeOptionTag(btn) {
    if (!btn) return;
    var container=btn.closest('.tag-container'); if (!container) return;
    btn.parentElement.remove();
    var tags=container.querySelectorAll('.tag');
    if (tags.length===0) { var p=container.querySelector('.placeholder-msg'); if(p) p.style.display=''; }
    updateEnumHidden(container);
}

function updateEnumHidden(container) {
    if (!container) return;
    var hidden=container.querySelector('.field-enum'); if (!hidden) return;
    var values=[]; container.querySelectorAll('.tag').forEach(function(t){ values.push(t.dataset.val); }); hidden.value=values.join(',');
}

function removeField(button) {
    if (!button) return;
    var row=button.closest('tr'); if (!row) return;
    var trIndex=row.dataset.index, tbody=row.parentElement; if (!tbody) return;
    var targetDetailRow=tbody.querySelector('tr.detail-row[data-index="'+trIndex+'"]');
    row.classList.add('opacity-0','-translate-x-4','transition-all','duration-200');
    if (targetDetailRow) targetDetailRow.classList.add('opacity-0','-translate-x-4');
    setTimeout(function(){ row.remove(); if(targetDetailRow) targetDetailRow.remove(); reindexFields(); updateFieldCount(); },200);
}

function reindexFields() {
    var rows=document.querySelectorAll('#fieldsTable tbody tr.field-row');
    rows.forEach(function(row,rowIndex) {
        row.dataset.index=rowIndex;
        row.querySelectorAll('[data-field]').forEach(function(input){ input.name='Fields['+rowIndex+'].'+input.dataset.field; });
        var tbody=row.parentElement;
        if (tbody) {
            var detailRows=tbody.querySelectorAll('tr.detail-row'), matchedDetail=detailRows[rowIndex];
            if (matchedDetail) {
                matchedDetail.dataset.index=rowIndex;
                matchedDetail.querySelectorAll('[data-field]').forEach(function(input){ input.name='Fields['+rowIndex+'].'+input.dataset.field; });
                var tagContainer=matchedDetail.querySelector('.tag-container'); if(tagContainer) tagContainer.dataset.row=rowIndex;
            }
        }
        updateValidationInputNames(row,rowIndex);
    });
    index=rows.length;
}

function updateValidationInputNames(row, rowIndex) {
    if (!row) return;
    if (rowIndex===undefined) {
        var tbodyEl=row.parentElement; if (!tbodyEl) return;
        rowIndex=Array.from(tbodyEl.children).filter(function(r){ return r.classList.contains('field-row'); }).indexOf(row);
    }
    var tbody=row.parentElement; if (!tbody) return;
    var detailRow=tbody.querySelector('tr.detail-row[data-index="'+row.dataset.index+'"]'); if (!detailRow) return;
    var typeSelect=row.querySelector('.field-type'); if (!typeSelect) return;
    var type=typeSelect.value, minInput=detailRow.querySelector('.field-min'), maxInput=detailRow.querySelector('.field-max');
    var minLabel=detailRow.querySelector('.min-label'), maxLabel=detailRow.querySelector('.max-label');
    if (!minInput||!maxInput) return;
    var numeric=type==='int'||type==='decimal', isEnum=type==='enum', isRelation=type==='relation';
    minInput.removeAttribute('name'); maxInput.removeAttribute('name');
    minInput.disabled=isEnum||isRelation; maxInput.disabled=isEnum||isRelation;
    minInput.step='1'; maxInput.step='1';
    if (type==='string') { minInput.name='Fields['+rowIndex+'].MinLength'; maxInput.name='Fields['+rowIndex+'].MaxLength'; if(minLabel) minLabel.textContent='Min Length'; if(maxLabel) maxLabel.textContent='Max Length'; }
    else if (numeric) { minInput.name='Fields['+rowIndex+'].MinValue'; maxInput.name='Fields['+rowIndex+'].MaxValue'; if(minLabel) minLabel.textContent='Min Value'; if(maxLabel) maxLabel.textContent='Max Value'; if(type==='decimal'){minInput.step='0.01';maxInput.step='0.01';} }
    else { if(minLabel) minLabel.textContent='Min Config'; if(maxLabel) maxLabel.textContent='Max Config'; minInput.value=''; maxInput.value=''; }
}

/* ══════════════════════════════════
   INIT
══════════════════════════════════ */
document.addEventListener('DOMContentLoaded', function() {
    renderSidebar();

    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('relation-pivot-cb')) {
            var val=e.target.checked?'true':'false';
            var existing=document.getElementById('relationFieldsContainer').querySelector('input[name="_rel_IsPivot"]');
            if (existing) existing.value=val;
        }
    });

    var toggler=document.querySelector('.toggler-relation'), selector=document.getElementById('relationSelector');
    if (toggler&&selector) {
        toggler.addEventListener('change', function() {
            if (toggler.checked) { selector.classList.remove('opacity-50','pointer-events-none'); selector.classList.add('animate-fadeIn'); }
            else { selector.classList.add('opacity-50','pointer-events-none'); selector.classList.remove('animate-fadeIn'); clearRelation(); }
        });
    }
});
</script>
