@model UserApp.Web.ViewModels.MilkViewModel

<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="mb-8">
        <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Milks
        </a>
        <h1 class="text-3xl font-black text-slate-800 tracking-tight mt-2">Create Milk</h1>
        <p class="text-slate-500 text-sm mt-1">Add a new milk product to your inventory</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-rose-600 mb-6 text-sm font-medium"></div>

            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-bold text-slate-700 mb-1.5">Name</label>
                    <input asp-for="Name"
                           class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 font-medium placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200" />
                    <span asp-validation-for="Name" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Price" class="block text-sm font-bold text-slate-700 mb-1.5">Price</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">$</span>
                        <input asp-for="Price"
                               class="w-full pl-8 pr-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 font-medium focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-all duration-200" />
                    </div>
                    <span asp-validation-for="Price" class="text-xs text-rose-500 mt-1"></span>
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1.5">Images</label>
                    <div class="relative">
                        <input type="file" name="files" multiple
                               class="peer absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                               onchange="updateFileLabel(this)" />
                        <div class="flex flex-col items-center justify-center gap-2 px-6 py-8 rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 text-slate-400 peer-hover:border-indigo-400 peer-hover:bg-indigo-50/50 transition-all duration-200">
                            <svg class="w-10 h-10 text-slate-300 peer-hover:text-indigo-400 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span id="fileLabel" class="text-sm font-medium">Choose images or drag here</span>
                            <span class="text-xs text-slate-400">Supports JPG, PNG, WEBP &bull; Max 5MB each</span>
                        </div>
                    </div>
                    @Html.ValidationMessage("files", new { @class = "text-xs text-rose-500 mt-1" })
                </div>
            </div>

            <div class="flex items-center gap-3 mt-8 pt-6 border-t border-slate-100">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl shadow-lg shadow-indigo-200 hover:shadow-indigo-300 transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Save Milk
                </button>
                <a asp-action="Index"
                   class="px-6 py-2.5 text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function updateFileLabel(input) {
        const label = document.getElementById('fileLabel');
        if (input.files.length > 0) {
            label.textContent = input.files.length + ' file(s) selected';
        } else {
            label.textContent = 'Choose images or drag here';
        }
    }
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .input-validation-error {
        border-color: #f43f5e !important;
        background-color: #fff1f2 !important;
    }
    .field-validation-error {
        color: #f43f5e;
        font-size: 0.75rem;
        margin-top: 0.25rem;
        display: block;
    }
    .validation-summary-errors {
        color: #f43f5e;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }
    .validation-summary-errors ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .validation-summary-errors li {
        padding: 0.25rem 0;
    }
</style>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
