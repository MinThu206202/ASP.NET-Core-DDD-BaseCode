<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserApp</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
        body {
            font-family: 'Lato', sans-serif;
            background-color: #f8fafc;
        }
        /* Custom scrollbar for a cleaner look */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        .input-validation-error {
            border-color: #f43f5e !important;
            background-color: #fff1f2 !important;
        }
        .field-validation-error {
            color: #f43f5e;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }
        .validation-summary-errors {
            color: #f43f5e;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .validation-summary-errors li {
            padding: 0.25rem 0;
        }

        /* --- Custom Keyframe Animations for Pill Toasts --- */
        @@keyframes toastSlideIn {
            0% {
                transform: translateX(calc(100% + 24px)) scale(0.92);
                opacity: 0;
            }
            100% {
                transform: translateX(0) scale(1);
                opacity: 1;
            }
        }
        @@keyframes toastSlideOut {
            0% {
                transform: translateX(0) scale(1);
                opacity: 1;
                max-height: 120px;
                margin-bottom: 0.75rem;
            }
            100% {
                transform: translateX(calc(100% + 24px)) scale(0.9);
                opacity: 0;
                max-height: 0;
                margin-bottom: 0;
                padding-top: 0;
                padding-bottom: 0;
            }
        }
        @@keyframes toastProgressBar {
            from {
                width: 100%;
            }
            to {
                width: 0%;
            }
        }

        /* Classes mapped to interactive transitions */
        .toast-notification {
            transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .toast-notification-enter {
            animation: toastSlideIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .toast-notification-exit {
            animation: toastSlideOut 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .toast-progress-bar {
            animation: toastProgressBar 5s linear forwards;
        }

        /* Pause interaction configuration */
        .toast-notification:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px -4px rgba(0, 0, 0, 0.08) !important;
        }
        .toast-notification:hover .toast-progress-bar {
            animation-play-state: paused;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased">

    <!-- Fixed Right-Side Toast Notification Container -->
    <div id="toastContainer" class="fixed top-6 right-0 z-[9999] flex flex-col gap-2 w-full max-w-[340px] pointer-events-none pl-3">
        
        <!-- SUCCESS TOAST -->
        @if (TempData["Success"] is string successMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white/95 backdrop-blur-md rounded-l-3xl rounded-r-none shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-500 shrink-0 flex items-center justify-center shadow-sm">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-bold text-slate-800 tracking-tight">Success</span>
                        <span class="text-sm font-medium text-slate-500 truncate mt-0.5">@successMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[2.5px] bg-emerald-400/50 toast-progress-bar origin-left"></div>
            </div>
        }

        <!-- ERROR TOAST -->
        @if (TempData["Error"] is string errorMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white/95 backdrop-blur-md rounded-l-3xl rounded-r-none shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-red-400 to-red-500 shrink-0 flex items-center justify-center shadow-sm">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-bold text-slate-800 tracking-tight">Error</span>
                        <span class="text-sm font-medium text-slate-500 truncate mt-0.5">@errorMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[2.5px] bg-red-400/50 toast-progress-bar origin-left"></div>
            </div>
        }

        <!-- WARNING TOAST -->
        @if (TempData["Warning"] is string warningMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white/95 backdrop-blur-md rounded-l-3xl rounded-r-none shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-500 shrink-0 flex items-center justify-center shadow-sm">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-bold text-slate-800 tracking-tight">Warning</span>
                        <span class="text-sm font-medium text-slate-500 truncate mt-0.5">@warningMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[2.5px] bg-amber-400/50 toast-progress-bar origin-left"></div>
            </div>
        }

        <!-- INFO TOAST -->
        @if (TempData["Info"] is string infoMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white/95 backdrop-blur-md rounded-l-3xl rounded-r-none shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-sky-500 shrink-0 flex items-center justify-center shadow-sm">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 101.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-tight">
                        <span class="text-sm font-bold text-slate-800 tracking-tight">Info</span>
                        <span class="text-sm font-medium text-slate-500 truncate mt-0.5">@infoMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[2.5px] bg-sky-400/50 toast-progress-bar origin-left"></div>
            </div>
        }
    </div>

    <header class="md:hidden bg-slate-900 text-white flex items-center justify-between px-4 py-3 shadow-md fixed top-0 left-0 right-0 z-50">
        <span class="text-xl font-black tracking-wider text-indigo-400">UserApp Suite</span>
        <button id="mobileMenuBtn" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 focus:outline-none transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </header>

    <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-slate-900 text-slate-300 transform -translate-x-full md:translate-x-0 flex flex-col transition-transform duration-300 ease-in-out border-r border-slate-800 shadow-xl">
        
        <div class="px-6 py-5 flex flex-col h-full justify-between overflow-y-auto">
            <div>
                <div class="flex items-center space-x-3 mb-8">
                    <div class="p-2 bg-indigo-600 rounded-xl text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                    </div>
                    <span class="text-xl font-black tracking-wider text-white">UserApp Suite</span>
                </div>

                <nav class="space-y-1">
                    <a asp-controller="Milk" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                        Milks
                    </a>
                    <a asp-controller="Pap" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        Paps
                    </a>
                    <a asp-controller="Users" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        Users
                    </a>
                    <a asp-controller="Roles" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        Roles
                    </a>
                    <a asp-controller="Permissions" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Permissions
                    </a>
                    <a asp-controller="Category" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Categories
                    </a>
                    <a asp-controller="CommonTable" asp-action="Index" 
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-bold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        <svg class="w-5 h-5 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Common Tables
                    </a>
                </nav>
            </div>

            <!-- Profile Info Widget inside Sidebar -->
            <div class="pt-6 border-t border-slate-800 flex items-center space-x-3">
                <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold text-sm">
                    @(!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name.Substring(0, Math.Min(3, User.Identity.Name.Length)).ToUpper() : "ADM")
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold text-white truncate">@(User.Identity?.Name ?? "System Administrator")</p>
                    <p class="text-[10px] text-slate-500 truncate">Active Identity Mapping</p>
                </div>
            </div>
        </div>
    </aside>

    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity"></div>

    <div class="md:ml-64 flex flex-col h-screen">
        
        <header class="hidden md:flex items-center justify-end bg-white border-b border-slate-200 px-10 py-3.5 h-16 sticky top-0 z-20 shadow-sm">
            <div class="relative inline-block text-left" id="profileDropdownWrapper">
                <button type="button" id="dropdownToggleBtn" 
                        class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-50 border border-slate-200 text-slate-700 font-bold text-sm rounded-xl hover:bg-slate-100 transition-all duration-150 focus:outline-none">
                    <div class="w-6 h-6 rounded-full bg-indigo-600 text-white font-black text-[11px] flex items-center justify-center shadow-sm">
                        @(!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper() : "U")
                    </div>
                    <span>@(User.Identity?.Name ?? "System Admin")</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200" id="dropdownArrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div id="userDropdownPanel" 
                     class="hidden absolute right-0 mt-2 w-48 bg-white border border-slate-200 rounded-xl shadow-xl py-1 z-50 animate-fade-in origin-top-right transform scale-95 opacity-0 transition-all duration-150">
                    <div class="px-4 py-2 border-b border-slate-100 bg-slate-50/50">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Account Context</p>
                        <p class="text-xs font-bold text-slate-700 truncate mt-0.5">@(User.Identity?.Name ?? "Administrator")</p>
                    </div>
                    <a asp-controller="Account" asp-action="Profile" 
                       class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-indigo-50/50 hover:text-indigo-600 transition-colors">
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        View Profile
                    </a>
                    <div class="border-t border-slate-100 my-1"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="w-full">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="w-full flex items-center gap-2 px-4 py-2.5 text-sm font-bold text-rose-600 hover:bg-rose-50 transition-colors text-left">
                            <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto px-4 pt-20 pb-6 md:pt-8 md:px-10 md:pb-8">
            @RenderBody()
        </main>
    </div>

    <!-- Scripting Context -->
    <script>
        // Dismiss toast functionality (Close & Exit animations)
        function dismissToast(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                // Remove entrance class and add departure class
                el.classList.remove('toast-notification-enter');
                el.classList.add('toast-notification-exit');
                
                // Remove element completely once exit animation has ended
                el.addEventListener('animationend', function handler(e) {
                    if (e.animationName === 'toastSlideOut') {
                        el.remove();
                    }
                });
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            // Interactive Timer Handler
            const flashMsg = document.getElementById('flashMessage');
            if (flashMsg) {
                const progressBar = flashMsg.querySelector('.toast-progress-bar');
                
                // If progress bar finishes its animation, automatically dismiss the toast
                if (progressBar) {
                    progressBar.addEventListener('animationend', function() {
                        dismissToast('flashMessage');
                    });
                }
            }

            // Mobile Sidebar elements
            const mobileMenuBtn = document.getElementById("mobileMenuBtn");
            const sidebar = document.getElementById("sidebar");
            const sidebarOverlay = document.getElementById("sidebarOverlay");

            function toggleSidebar() {
                sidebar.classList.toggle("-translate-x-full");
                sidebarOverlay.classList.toggle("hidden");
            }

            if (mobileMenuBtn && sidebar && sidebarOverlay) {
                mobileMenuBtn.addEventListener("click", toggleSidebar);
                sidebarOverlay.addEventListener("click", toggleSidebar);
            }

            // Desktop User Profile Dropdown Interactions
            const dropdownToggleBtn = document.getElementById("dropdownToggleBtn");
            const userDropdownPanel = document.getElementById("userDropdownPanel");
            const dropdownArrow = document.getElementById("dropdownArrow");

            function toggleDropdown(e) {
                e.stopPropagation();
                const isHidden = userDropdownPanel.classList.contains("hidden");
                
                if (isHidden) {
                    // Open Panel Action
                    userDropdownPanel.classList.remove("hidden");
                    setTimeout(() => {
                        userDropdownPanel.classList.remove("scale-95", "opacity-0");
                        userDropdownPanel.classList.add("scale-100", "opacity-100");
                    }, 20);
                    dropdownArrow.classList.add("rotate-180");
                } else {
                    // Close Panel Action
                    userDropdownPanel.classList.remove("scale-100", "opacity-100");
                    userDropdownPanel.classList.add("scale-95", "opacity-0");
                    dropdownArrow.classList.remove("rotate-180");
                    setTimeout(() => userDropdownPanel.classList.add("hidden"), 150);
                }
            }

            if (dropdownToggleBtn && userDropdownPanel) {
                dropdownToggleBtn.addEventListener("click", toggleDropdown);

                // Safe click-away close strategy
                document.addEventListener("click", function (event) {
                    if (!userDropdownPanel.classList.contains("hidden") && !document.getElementById("profileDropdownWrapper").contains(event.target)) {
                        userDropdownPanel.classList.remove("scale-100", "opacity-100");
                        userDropdownPanel.classList.add("scale-95", "opacity-0");
                        dropdownArrow.classList.remove("rotate-180");
                        setTimeout(() => userDropdownPanel.classList.add("hidden"), 150);
                    }
                });
            }
        });
    </script>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="fixed inset-0 z-50 hidden" role="dialog">
        <div class="absolute inset-0 bg-black/50 transition-opacity"></div>
        <div class="flex items-center justify-center min-h-full p-4">
            <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 transform transition-all">
                <div class="flex items-center gap-4 mb-4">
                    <div class="p-2.5 rounded-full bg-rose-50">
                        <svg class="w-6 h-6 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Confirm Delete</h3>
                        <p class="text-sm text-slate-500 mt-0.5">Are you sure you want to delete this? This action cannot be undone.</p>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" id="cancelDeleteBtn" class="px-4 py-2 text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                        Cancel
                    </button>
                    <button type="button" id="confirmDeleteBtn" class="px-4 py-2 text-sm font-bold text-white bg-rose-600 hover:bg-rose-700 rounded-xl transition-colors shadow-sm">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal');
            var confirmBtn = document.getElementById('confirmDeleteBtn');
            var cancelBtn = document.getElementById('cancelDeleteBtn');
            var activeForm = null;

            function openModal(form) {
                activeForm = form;
                deleteModal.classList.remove('hidden');
            }

            function closeModal() {
                deleteModal.classList.add('hidden');
                activeForm = null;
            }

            document.querySelectorAll('[data-confirm-delete]').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    var form = btn.closest('form');
                    if (form) openModal(form);
                });
            });

            confirmBtn.addEventListener('click', function () {
                if (activeForm) {
                    activeForm.submit();
                }
                closeModal();
            });

            cancelBtn.addEventListener('click', closeModal);

            deleteModal.addEventListener('click', function (e) {
                if (e.target === deleteModal) closeModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeModal();
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>