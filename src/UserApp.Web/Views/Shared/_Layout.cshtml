@inject UserApp.Application.SidebarItems.Interfaces.ISidebarItemService SidebarService
@using System.Linq
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserApp</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
        body {
            font-family: 'Lato', sans-serif;
            background-color: #f8fafc;
        }
        /* Custom scrollbar for a cleaner look */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
        .input-validation-error {
            border-color: #f43f5e !important;
            background-color: #fff1f2 !important;
        }
        .field-validation-error {
            color: #f43f5e;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }
        .validation-summary-errors {
            color: #f43f5e;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .validation-summary-errors li {
            padding: 0.25rem 0;
        }

        /* --- Custom Keyframe Animations for Pill Toasts --- */
        @@keyframes toastSlideIn {
            0% {
                transform: translateX(calc(100% + 24px)) scale(0.92);
                opacity: 0;
            }
            60% {
                transform: translateX(-8px) scale(1.01);
                opacity: 1;
            }
            80% {
                transform: translateX(4px) scale(0.99);
            }
            100% {
                transform: translateX(0) scale(1);
                opacity: 1;
            }
        }
        @@keyframes toastSlideOut {
            0% {
                transform: translateX(0) scale(1);
                opacity: 1;
                max-height: 120px;
                margin-bottom: 0.75rem;
            }
            100% {
                transform: translateX(calc(100% + 24px)) scale(0.9);
                opacity: 0;
                max-height: 0;
                margin-bottom: 0;
                padding-top: 0;
                padding-bottom: 0;
            }
        }
        @@keyframes toastProgressBar {
            from {
                width: 100%;
            }
            to {
                width: 0%;
            }
        }

        /* Classes mapped to interactive transitions */
        .toast-notification {
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .toast-notification-enter {
            animation: toastSlideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        .toast-notification-exit {
            animation: toastSlideOut 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        .toast-progress-bar {
            animation: toastProgressBar 4.5s linear forwards;
        }

        /* Pause interaction configuration */
        .toast-notification:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 12px 30px -4px rgba(0, 0, 0, 0.12) !important;
        }
        .toast-notification:hover .toast-progress-bar {
            animation-play-state: paused;
        }

        .sidebar-children {
            display: none;
        }
        .sidebar-children.open {
            display: block;
        }
        @@keyframes waveDot {
            0%, 100% { transform: translateY(0); opacity: 0.4; }
            50% { transform: translateY(-10px); opacity: 1; }
        }
        .wave-dots {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .wave-dot {
            width: 16px; height: 16px;
            border-radius: 50%;
            background-color: #6366f1;
            animation: waveDot 1.2s ease-in-out infinite;
        }
        .wave-dot:nth-child(2) { animation-delay: 0.15s; }
        .wave-dot:nth-child(3) { animation-delay: 0.3s; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased">

    <!-- Fixed Right-Side Toast Notification Container -->
    <div id="toastContainer" class="fixed bottom-6 right-0 z-[9999] flex flex-col gap-2 w-full max-w-[280px] pointer-events-none">
        
        <!-- SUCCESS TOAST -->
        @if (TempData["Success"] is string successMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white rounded-l-[40px] rounded-r-none shadow-lg border border-emerald-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3.5">
                    <div class="w-9 h-9 rounded-full bg-emerald-500 shrink-0 flex items-center justify-center">
                        <svg class="w-[18px] h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-snug">
                        <span class="text-xs font-bold text-emerald-600 uppercase tracking-wider">Successful</span>
                        <span class="text-[15px] font-medium text-slate-700 mt-0.5">@successMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[3px] bg-emerald-400/60 toast-progress-bar origin-left rounded-r-full"></div>
            </div>
        }

        <!-- ERROR TOAST -->
        @if (TempData["Error"] is string errorMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white rounded-l-[40px] rounded-r-none shadow-lg border border-red-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3.5">
                    <div class="w-9 h-9 rounded-full bg-red-500 shrink-0 flex items-center justify-center">
                        <svg class="w-[18px] h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-snug">
                        <span class="text-xs font-bold text-red-600 uppercase tracking-wider">Error Occurred</span>
                        <span class="text-[15px] font-medium text-slate-700 mt-0.5">@errorMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[3px] bg-red-400/60 toast-progress-bar origin-left rounded-r-full"></div>
            </div>
        }

        <!-- WARNING TOAST -->
        @if (TempData["Warning"] is string warningMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white rounded-l-[40px] rounded-r-none shadow-lg border border-amber-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3.5">
                    <div class="w-9 h-9 rounded-full bg-amber-500 shrink-0 flex items-center justify-center">
                        <svg class="w-[18px] h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-snug">
                        <span class="text-xs font-bold text-amber-600 uppercase tracking-wider">Warning</span>
                        <span class="text-[15px] font-medium text-slate-700 mt-0.5">@warningMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[3px] bg-amber-400/60 toast-progress-bar origin-left rounded-r-full"></div>
            </div>
        }

        <!-- INFO TOAST -->
        @if (TempData["Info"] is string infoMsg)
        {
            <div id="flashMessage" class="toast-notification toast-notification-enter pointer-events-auto relative flex flex-col w-full bg-white rounded-l-[40px] rounded-r-none shadow-lg border border-sky-100 overflow-hidden">
                <div class="flex items-center gap-3 pl-4 pr-5 py-3.5">
                    <div class="w-9 h-9 rounded-full bg-sky-500 shrink-0 flex items-center justify-center">
                        <svg class="w-[18px] h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 101.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </svg>
                    </div>
                    <div class="flex flex-col min-w-0 leading-snug">
                        <span class="text-xs font-bold text-sky-600 uppercase tracking-wider">Information</span>
                        <span class="text-[15px] font-medium text-slate-700 mt-0.5">@infoMsg</span>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 h-[3px] bg-sky-400/60 toast-progress-bar origin-left rounded-r-full"></div>
            </div>
        }
    </div>

    <header class="md:hidden bg-slate-900 text-white flex items-center justify-between px-4 py-2.5 shadow-md fixed top-0 left-0 right-0 z-50">
        <span class="text-xl font-black tracking-wider text-indigo-400">UserApp Suite</span>
        <button id="mobileMenuBtn" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 focus:outline-none transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </header>

    <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-slate-900 text-slate-300 transform -translate-x-full md:translate-x-0 flex flex-col transition-transform duration-300 ease-in-out border-r border-slate-800 shadow-xl">
        
        <div class="px-6 py-5 flex flex-col h-full overflow-y-auto">
            <div class="flex-1 min-h-0">
                <div class="flex items-center space-x-3 mb-8">
                    <div class="p-2 bg-indigo-600 rounded-xl text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                    </div>
                    <span class="text-xl font-black tracking-wider text-white">UserApp Suite</span>
                </div>
<nav class="space-y-1">
@{
    var sidebarItems = await SidebarService.GetActiveAsync();
    var nonSystemItems = sidebarItems.Where(x => x.Group.Name != "System").ToList();
    var systemItems = sidebarItems.Where(x => x.Group.Name == "System").ToList();
    var allGroups = nonSystemItems.GroupBy(x => x.Group.Name).OrderBy(g => g.Key);

    foreach (var group in allGroups)
    {
        var sectionId = group.Key.ToLower().Replace(" ", "-") + "-section";
        <div class="sidebar-section">
            <button onclick="toggleSidebarSection('@sectionId')" class="w-full flex items-center justify-between px-4 py-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest hover:text-slate-300 transition-colors">
                <span>@group.Key</span>
                <svg class="w-3 h-3 transition-transform duration-200" id="chev-@sectionId" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="@sectionId" class="sidebar-children">
                @foreach (var item in group.OrderBy(x => x.DisplayOrder))
                {
                    <a asp-controller="@item.ControllerName" asp-action="Index"
                       class="flex items-center px-4 py-2 rounded-lg text-sm font-semibold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                        @if (!string.IsNullOrEmpty(item.IconSvg))
                        {
                            @Html.Raw(item.IconSvg)
                        }
                        else
                        {
                            <svg class="w-4 h-4 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        }
                        @item.ModuleName
                    </a>
                }
            </div>
        </div>
    }
}
</nav>
            </div>

            <!-- System Dropdown (pinned) -->
            @if (systemItems.Any())
            {
                var systemGroup = systemItems.GroupBy(x => x.Group!.Name).First();
                var sectionId = "system-section";
                <div class="sidebar-section flex-shrink-0 pt-4 border-t border-slate-800 mt-4">
                    <button onclick="toggleSidebarSection('@sectionId')" class="w-full flex items-center justify-between px-4 py-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest hover:text-slate-300 transition-colors">
                        <span>System</span>
                        <svg class="w-3 h-3 transition-transform duration-200" id="chev-@sectionId" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div id="@sectionId" class="sidebar-children">
                        @foreach (var item in systemGroup.OrderBy(x => x.DisplayOrder))
                        {
                            <a asp-controller="@item.ControllerName" asp-action="Index"
                               class="flex items-center px-4 py-2 rounded-lg text-sm font-semibold tracking-wide transition-all duration-150 group hover:bg-slate-800 hover:text-white">
                                @if (!string.IsNullOrEmpty(item.IconSvg))
                                {
                                    @Html.Raw(item.IconSvg)
                                }
                                else
                                {
                                    <svg class="w-4 h-4 mr-3 text-slate-400 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                                    </svg>
                                }
                                @item.ModuleName
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Profile Info Widget inside Sidebar -->
        </div>
    </aside>

    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden transition-opacity"></div>

    <div class="md:ml-64 flex flex-col h-screen">
        
        <header class="hidden md:flex items-center justify-end bg-white border-b border-slate-200 px-10 py-3.5 h-16 sticky top-0 z-20 shadow-sm">
            <div class="relative inline-block text-left" id="profileDropdownWrapper">
                <button type="button" id="dropdownToggleBtn" 
                        class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-50 border border-slate-200 text-slate-700 font-bold text-sm rounded-xl hover:bg-slate-100 transition-all duration-150 focus:outline-none">
                    <div class="w-6 h-6 rounded-full bg-indigo-600 text-white font-black text-[11px] flex items-center justify-center shadow-sm">
                        @(!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper() : "U")
                    </div>
                    <span>@(User.Identity?.Name ?? "System Admin")</span>
                    <svg class="w-4 h-4 text-slate-400 transition-transform duration-200" id="dropdownArrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div id="userDropdownPanel" 
                     class="hidden absolute right-0 mt-2 w-48 bg-white border border-slate-200 rounded-xl shadow-xl py-1 z-50 animate-fade-in origin-top-right transform scale-95 opacity-0 transition-all duration-150">
                    <div class="px-4 py-2 border-b border-slate-100 bg-slate-50/50">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Account Context</p>
                        <p class="text-xs font-bold text-slate-700 truncate mt-0.5">@(User.Identity?.Name ?? "Administrator")</p>
                    </div>
                    <a asp-controller="Account" asp-action="Profile" 
                       class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-indigo-50/50 hover:text-indigo-600 transition-colors">
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        View Profile
                    </a>
                    <div class="border-t border-slate-100 my-1"></div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="w-full">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="w-full flex items-center gap-2 px-4 py-2.5 text-sm font-bold text-rose-600 hover:bg-rose-50 transition-colors text-left">
                            <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                            </svg>
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto px-4 pt-20 pb-6 md:pt-8 md:px-10 md:pb-8">
            @RenderBody()
        </main>
    </div>

    <!-- Scripting Context -->
    <script>
        // Dismiss toast functionality (Close & Exit animations)
        function dismissToast(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                // Remove entrance class and add departure class
                el.classList.remove('toast-notification-enter');
                el.classList.add('toast-notification-exit');
                
                // Remove element completely once exit animation has ended
                el.addEventListener('animationend', function handler(e) {
                    if (e.animationName === 'toastSlideOut') {
                        el.remove();
                    }
                });
            }
        }

        function toggleSidebarSection(id) {
            const section = document.getElementById(id);
            const chev = document.getElementById('chev-' + id);
            if (section) {
                const isOpen = section.classList.toggle('open');
                if (chev) chev.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
                localStorage.setItem('sidebarSection_' + id, isOpen ? 'open' : 'closed');
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            // Interactive Timer Handler
            const flashMsg = document.getElementById('flashMessage');
            if (flashMsg) {
                const progressBar = flashMsg.querySelector('.toast-progress-bar');
                
                // If progress bar finishes its animation, automatically dismiss the toast
                if (progressBar) {
                    progressBar.addEventListener('animationend', function() {
                        dismissToast('flashMessage');
                    });
                }
            }

            // Mobile Sidebar elements
            const mobileMenuBtn = document.getElementById("mobileMenuBtn");
            const sidebar = document.getElementById("sidebar");
            const sidebarOverlay = document.getElementById("sidebarOverlay");

            function toggleSidebar() {
                sidebar.classList.toggle("-translate-x-full");
                sidebarOverlay.classList.toggle("hidden");
            }

            if (mobileMenuBtn && sidebar && sidebarOverlay) {
                mobileMenuBtn.addEventListener("click", toggleSidebar);
                sidebarOverlay.addEventListener("click", toggleSidebar);
            }

            // Desktop User Profile Dropdown Interactions
            const dropdownToggleBtn = document.getElementById("dropdownToggleBtn");
            const userDropdownPanel = document.getElementById("userDropdownPanel");
            const dropdownArrow = document.getElementById("dropdownArrow");

            // Restore sidebar section states
            document.querySelectorAll('.sidebar-section').forEach(function (section) {
                const btn = section.querySelector('button');
                if (btn && btn.getAttribute('onclick')) {
                    const match = btn.getAttribute('onclick').match(/'([^']+)'/);
                    if (match) {
                        const id = match[1];
                        const state = localStorage.getItem('sidebarSection_' + id);
                        if (state !== 'closed') {
                            const div = document.getElementById(id);
                            const chev = document.getElementById('chev-' + id);
                            if (div) div.classList.add('open');
                            if (chev) chev.style.transform = 'rotate(180deg)';
                        }
                    }
                }
            });

            function toggleDropdown(e) {
                e.stopPropagation();
                const isHidden = userDropdownPanel.classList.contains("hidden");
                
                if (isHidden) {
                    // Open Panel Action
                    userDropdownPanel.classList.remove("hidden");
                    setTimeout(() => {
                        userDropdownPanel.classList.remove("scale-95", "opacity-0");
                        userDropdownPanel.classList.add("scale-100", "opacity-100");
                    }, 20);
                    dropdownArrow.classList.add("rotate-180");
                } else {
                    // Close Panel Action
                    userDropdownPanel.classList.remove("scale-100", "opacity-100");
                    userDropdownPanel.classList.add("scale-95", "opacity-0");
                    dropdownArrow.classList.remove("rotate-180");
                    setTimeout(() => userDropdownPanel.classList.add("hidden"), 150);
                }
            }

            if (dropdownToggleBtn && userDropdownPanel) {
                dropdownToggleBtn.addEventListener("click", toggleDropdown);

                // Safe click-away close strategy
                document.addEventListener("click", function (event) {
                    if (!userDropdownPanel.classList.contains("hidden") && !document.getElementById("profileDropdownWrapper").contains(event.target)) {
                        userDropdownPanel.classList.remove("scale-100", "opacity-100");
                        userDropdownPanel.classList.add("scale-95", "opacity-0");
                        dropdownArrow.classList.remove("rotate-180");
                        setTimeout(() => userDropdownPanel.classList.add("hidden"), 150);
                    }
                });
            }
        });
    </script>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 z-[9999] hidden" style="align-items:center;justify-content:center;flex-direction:column;gap:16px;background:#fff">
        <div class="wave-dots">
            <div class="wave-dot"></div>
            <div class="wave-dot"></div>
            <div class="wave-dot"></div>
        </div>
        <span class="text-sm font-semibold text-slate-700" id="loadingOverlayText">Processing...</span>
    </div>

    <!-- Confirm Modal -->
    <div id="confirmModal" class="fixed inset-0 z-50 hidden" role="dialog">
        <div class="absolute inset-0 bg-black/50 transition-opacity"></div>
        <div class="flex items-center justify-center min-h-full p-4">
            <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 transform transition-all">
                <div class="flex items-center gap-4 mb-4">
                    <div class="p-2.5 rounded-full bg-indigo-50" id="confirmModalIcon">
                        <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800" id="confirmModalTitle">Confirm Action</h3>
                        <p class="text-sm text-slate-500 mt-0.5" id="confirmModalMessage">Are you sure?</p>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" id="confirmModalCancel" class="px-4 py-2 text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                        Cancel
                    </button>
                    <button type="button" id="confirmModalOk" class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-colors shadow-sm">
                        Confirm
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var confirmModal = document.getElementById('confirmModal');
            var confirmOkBtn = document.getElementById('confirmModalOk');
            var confirmCancelBtn = document.getElementById('confirmModalCancel');
            var confirmTitle = document.getElementById('confirmModalTitle');
            var confirmMessage = document.getElementById('confirmModalMessage');
            var confirmIcon = document.getElementById('confirmModalIcon');
            var activeForm = null;
            var loadingOverlay = document.getElementById('loadingOverlay');

            function showLoading(msg) {
                var el = document.getElementById('loadingOverlayText');
                if (el && msg) el.textContent = msg;
                loadingOverlay.style.display = 'flex';
                loadingOverlay.classList.remove('hidden');
            }

            var confirmStyles = {
                indigo: { btn: 'bg-indigo-600 hover:bg-indigo-700', iconBg: 'bg-indigo-50', icon: 'text-indigo-500' },
                emerald: { btn: 'bg-emerald-600 hover:bg-emerald-700', iconBg: 'bg-emerald-50', icon: 'text-emerald-500' },
                orange: { btn: 'bg-orange-600 hover:bg-orange-700', iconBg: 'bg-orange-50', icon: 'text-orange-500' },
                rose: { btn: 'bg-rose-600 hover:bg-rose-700', iconBg: 'bg-rose-50', icon: 'text-rose-500' }
            };

            function openConfirmModal(form, title, message, okText, color) {
                activeForm = form;
                if (title) confirmTitle.textContent = title;
                if (message) confirmMessage.textContent = message;
                if (okText) confirmOkBtn.textContent = okText;
                var cs = confirmStyles[color] || confirmStyles.indigo;
                confirmOkBtn.className = 'px-4 py-2 text-sm font-bold text-white rounded-xl transition-colors shadow-sm ' + cs.btn;
                confirmIcon.innerHTML = '<svg class="w-6 h-6 ' + cs.icon + '" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>';
                confirmIcon.className = 'p-2.5 rounded-full ' + cs.iconBg;
                confirmModal.classList.remove('hidden');
            }

            function closeConfirmModal() {
                confirmModal.classList.add('hidden');
                activeForm = null;
            }

            // Backward compat: data-confirm-delete → data-confirm
            document.querySelectorAll('[data-confirm-delete]').forEach(function (btn) {
                btn.setAttribute('data-confirm', btn.getAttribute('data-confirm-delete') || 'Delete this?');
                btn.setAttribute('data-confirm-title', 'Confirm Delete');
                btn.setAttribute('data-confirm-ok', 'Delete');
                btn.setAttribute('data-confirm-color', 'rose');
                btn.setAttribute('data-loading-text', 'Deleting...');
            });

            document.querySelectorAll('[data-confirm]').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    var form = btn.closest('form');
                    if (!form) return;
                    var msg = btn.getAttribute('data-confirm') || 'Are you sure?';
                    var title = btn.getAttribute('data-confirm-title') || 'Confirm Action';
                    var okText = btn.getAttribute('data-confirm-ok') || 'Confirm';
                    var color = btn.getAttribute('data-confirm-color') || 'indigo';
                    openConfirmModal(form, title, msg, okText, color);
                });
            });

            confirmOkBtn.addEventListener('click', function () {
                if (activeForm) {
                    var btn = activeForm.querySelector('[data-confirm]');
                    var loadingMsg = btn ? (btn.getAttribute('data-loading-text') || btn.textContent.trim() || 'Processing...') : 'Processing...';
                    showLoading(loadingMsg);
                    activeForm.submit();
                }
                closeConfirmModal();
            });

            confirmCancelBtn.addEventListener('click', closeConfirmModal);

            confirmModal.addEventListener('click', function (e) {
                if (e.target === confirmModal) closeConfirmModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeConfirmModal();
            });

            // Loading overlay on form submit
            document.addEventListener('submit', function (e) {
                var form = e.target;
                if (form.hasAttribute('data-no-loading')) return;
                if (form.matches('[style*="display:inline"], [style*="display: inline"]')) return;
                if (form.closest('#confirmModal')) return;
                if (form.id === 'generateForm') return;
                var btn = form.querySelector('[type="submit"]');
                if (btn) showLoading(btn.value || btn.textContent.trim() || 'Processing...');
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>