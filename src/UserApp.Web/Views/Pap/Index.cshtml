@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.PapViewModel>

<h2>Paps</h2>

<a asp-action="Create" class="btn btn-success">Create Pap</a>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
<th>Name</th>
<th>Image</th>

            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var p in Model.Items)
{
        <tr>
            <td>@p.Id</td>
<td>@p.Name</td>
<td><img src="@p.ImageUrl" width="50" /></td>

            <td>
                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
}
    </tbody>
</table>
