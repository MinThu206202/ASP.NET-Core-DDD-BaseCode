@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.AuditLogs.AuditLogViewModel>

<div class="overflow-x-auto">
    <table class="w-full">
        <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Time</th>
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">User</th>
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Action</th>
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Entity</th>
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Page</th>
                <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Changed Fields</th>
                <th class="text-right px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
@foreach (var log in Model.Items)
{
            <tr class="hover:bg-indigo-50/40 transition-colors duration-150">
                <td class="px-6 py-4 text-sm text-slate-600 whitespace-nowrap">@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="px-6 py-4 font-medium text-slate-800">@log.UserName</td>
                <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                        @(log.Action switch
                        {
                            "Create" => "bg-green-100 text-green-700",
                            "Update" => "bg-amber-100 text-amber-700",
                            "Delete" => "bg-rose-100 text-rose-700",
                            _ => "bg-slate-100 text-slate-600"
                        })">
                        @log.Action
                    </span>
                </td>
                <td class="px-6 py-4 text-sm text-slate-600">
                    <span class="font-medium text-slate-700">@log.EntityName</span>
                    <span class="text-slate-400 ml-1">#@log.EntityId[..Math.Min(8, log.EntityId.Length)]</span>
                </td>
                <td class="px-6 py-4 text-sm text-slate-500">@log.PageName</td>
                <td class="px-6 py-4">
                    @if (!string.IsNullOrEmpty(log.AffectedColumns))
                    {
                        var cols = System.Text.Json.JsonSerializer.Deserialize<List<string>>(log.AffectedColumns);
                        if (cols != null && cols.Count > 0)
                        {
                            <div class="group relative inline-flex items-center gap-1">
                            @foreach (var col in cols.Take(2))
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-600">@col</span>
                            }
                            @if (cols.Count > 2)
                            {
                                <span class="text-xs font-bold text-slate-400 ml-0.5">+@(cols.Count - 2)</span>
                                <div class="absolute bottom-full left-0 mb-2 hidden group-hover:block z-20">
                                    <div class="flex flex-wrap gap-1 p-2 bg-slate-800 rounded-lg shadow-xl">
                                    @foreach (var col in cols)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-500 text-white">@col</span>
                                    }
                                    </div>
                                </div>
                            }
                            </div>
                        }
                    }
                </td>
                <td class="px-6 py-4 text-right">
                    <div class="inline-flex items-center gap-1.5">
                        <a asp-action="Details" asp-route-id="@log.Id"
                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            View
                        </a>
                        @if (log.Action == "Delete")
                        {
                            <form asp-action="Restore" asp-route-id="@log.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="button"
                                        data-confirm="Restore this @log.EntityName?"
                                        data-confirm-title="Restore"
                                        data-confirm-ok="Restore"
                                        data-confirm-color="emerald"
                                        data-loading-text="Restoring..."
                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-emerald-600 bg-emerald-50 hover:bg-emerald-100 rounded-lg transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                    </svg>
                                    Restore
                                </button>
                            </form>
                        }
                        @if (log.Action == "Update")
                        {
                            <form asp-action="Revert" asp-route-id="@log.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="button"
                                        data-confirm="Revert this @log.EntityName to its previous values?"
                                        data-confirm-title="Revert Changes"
                                        data-confirm-ok="Revert"
                                        data-confirm-color="orange"
                                        data-loading-text="Reverting..."
                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-orange-600 bg-orange-50 hover:bg-orange-100 rounded-lg transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                    </svg>
                                    Revert
                                </button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-16">
        <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-slate-500 font-medium">@(string.IsNullOrEmpty(Model.SearchTerm) ? "No audit logs yet" : "No matching audit logs")</p>
        <p class="text-slate-400 text-sm mt-1">@(string.IsNullOrEmpty(Model.SearchTerm) ? "Changes will appear here as they happen." : "Try a different search term.")</p>
    </div>
}

<input type="hidden" id="currentPage" value="@Model.Page" />
<input type="hidden" id="totalCount" value="@Model.TotalCount" />
