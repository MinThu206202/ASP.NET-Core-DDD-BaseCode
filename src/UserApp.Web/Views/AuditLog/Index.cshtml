@model UserApp.Web.ViewModels.ListViewModel<UserApp.Web.ViewModels.AuditLogs.AuditLogViewModel>

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Audit Logs</h1>
            <p class="text-slate-500 text-sm mt-1">Track all changes made across the system</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Time</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">User</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Action</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Entity</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Page</th>
                        <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Changed Fields</th>
                        <th class="text-right px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
@foreach (var log in Model.Items)
{
                    <tr class="hover:bg-indigo-50/40 transition-colors duration-150">
                        <td class="px-6 py-4 text-sm text-slate-600 whitespace-nowrap">@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-6 py-4 font-medium text-slate-800">@log.UserName</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                                @(log.Action switch
                                {
                                    "Create" => "bg-green-100 text-green-700",
                                    "Update" => "bg-amber-100 text-amber-700",
                                    "Delete" => "bg-rose-100 text-rose-700",
                                    _ => "bg-slate-100 text-slate-600"
                                })">
                                @log.Action
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">
                            <span class="font-medium text-slate-700">@log.EntityName</span>
                            <span class="text-slate-400 ml-1">#@log.EntityId[..Math.Min(8, log.EntityId.Length)]</span>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-500">@log.PageName</td>
                        <td class="px-6 py-4">
                            @if (!string.IsNullOrEmpty(log.AffectedColumns))
                            {
                                var cols = System.Text.Json.JsonSerializer.Deserialize<List<string>>(log.AffectedColumns);
                                if (cols != null)
                                {
                                    <div class="flex flex-wrap gap-1">
                                    @foreach (var col in cols)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-600">@col</span>
                                    }
                                    </div>
                                }
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="Details" asp-route-id="@log.Id"
                               class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                View
                            </a>
                        </td>
                    </tr>
}
                </tbody>
            </table>
        </div>

@if (!Model.Items.Any())
{
        <div class="text-center py-16">
            <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-slate-500 font-medium">No audit logs yet</p>
            <p class="text-slate-400 text-sm mt-1">Changes will appear here as they happen.</p>
        </div>
}
    </div>

@if (Model.TotalCount > Model.PageSize)
{
    <div class="flex items-center justify-between mt-6">
        <p class="text-sm text-slate-500">
            Showing <span class="font-bold">@((Model.Page - 1) * Model.PageSize + 1)</span>
            to <span class="font-bold">@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</span>
            of <span class="font-bold">@Model.TotalCount</span> items
        </p>
        <div class="flex gap-2">
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-size="@Model.PageSize"
                   class="px-4 py-2 text-sm font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors shadow-sm">
                    Previous
                </a>
            }
            @if (Model.Page * Model.PageSize < Model.TotalCount)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-size="@Model.PageSize"
                   class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                    Next
                </a>
            }
        </div>
    </div>
}
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
