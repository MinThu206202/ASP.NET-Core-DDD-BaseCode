@model UserApp.Web.ViewModels.AuditLogs.AuditLogViewModel

<div class="animate-fade-in max-w-4xl mx-auto">
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-500 hover:text-indigo-600 mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Audit Logs
    </a>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100">
            <h1 class="text-2xl font-black text-slate-800">Audit Log Detail</h1>
        </div>

        <div class="px-8 py-6 space-y-6">
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">User</label>
                    <p class="text-sm font-semibold text-slate-800">@Model.UserName</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Action</label>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold
                        @(Model.Action switch
                        {
                            "Create" => "bg-green-100 text-green-700",
                            "Update" => "bg-amber-100 text-amber-700",
                            "Delete" => "bg-rose-100 text-rose-700",
                            _ => "bg-slate-100 text-slate-600"
                        })">
                        @Model.Action
                    </span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Entity</label>
                    <p class="text-sm font-semibold text-slate-800">@Model.EntityName</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Entity ID</label>
                    <p class="text-sm font-mono text-slate-800">@Model.EntityId</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Page</label>
                    <p class="text-sm text-slate-800">@Model.PageName</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Function</label>
                    <p class="text-sm text-slate-800">@Model.FunctionName</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Timestamp</label>
                    <p class="text-sm text-slate-800">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Changed Fields</label>
                    @if (!string.IsNullOrEmpty(Model.AffectedColumns))
                    {
                        var cols = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.AffectedColumns);
                        if (cols != null)
                        {
                            <div class="flex flex-wrap gap-1 mt-1">
                            @foreach (var col in cols)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-600">@col</span>
                            }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-400">—</p>
                    }
                </div>
            </div>

            @if (Model.Action == "Update")
            {
                <div class="grid grid-cols-2 gap-6 pt-4 border-t border-slate-100">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Old Values</label>
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                            <partial name="_AuditLogValues" model="Model.OldValues" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">New Values</label>
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                            <partial name="_AuditLogValues" model="Model.NewValues" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Action == "Delete" && !string.IsNullOrEmpty(Model.OldValues))
            {
                <div class="pt-4 border-t border-slate-100">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Deleted Values</label>
                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                        <partial name="_AuditLogValues" model="Model.OldValues" />
                    </div>
                </div>
            }
        </div>

        <div class="px-8 py-4 border-t border-slate-100 bg-slate-50 flex gap-3">
            @if (Model.Action == "Delete")
            {
                <form asp-action="Restore" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button"
                            data-confirm="Restore this @Model.EntityName?"
                            data-confirm-title="Restore"
                            data-confirm-ok="Restore"
                            data-confirm-color="emerald"
                            data-loading-text="Restoring..."
                            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-700 rounded-xl transition-colors shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                        Restore
                    </button>
                </form>
            }
            @if (Model.Action == "Update" && !string.IsNullOrEmpty(Model.OldValues))
            {
                <form asp-action="Revert" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button"
                            data-confirm="Revert this @Model.EntityName to its previous values?"
                            data-confirm-title="Revert Changes"
                            data-confirm-ok="Revert"
                            data-confirm-color="orange"
                            data-loading-text="Reverting..."
                            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-orange-600 hover:bg-orange-700 rounded-xl transition-colors shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                        </svg>
                        Revert
                    </button>
                </form>
            }
            <a asp-action="Index"
               class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-slate-600 bg-white hover:bg-slate-100 rounded-xl transition-colors border border-slate-200 shadow-sm">
                Back to List
            </a>
        </div>
    </div>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
